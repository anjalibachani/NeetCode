class Solution {
    public int majorityElement(int[] nums) {
        int maj = nums.length/2;
        int ans = 0;
        for(int i = 0; i < nums.length; i++) {
            int count = 0;
            for(int j = 0; j < nums.length; j++) {
                if(nums[i] == nums[j]) {
                    count +=1;
                }
            }
            if(count > maj) {
                ans = nums[i];
            }
        }
        return ans;
    }
}